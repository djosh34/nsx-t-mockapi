#!/usr/bin/env sh
set -eu

log() {
	level="$1"
	action="$2"
	message="$3"
	printf '{"level":"%s","action":"%s","message":"%s"}\n' "$level" "$action" "$message" >&2
}

run_step() {
	action="$1"
	shift

	log "info" "$action" "starting"
	if "$@"; then
		log "info" "$action" "completed"
		return 0
	fi

	status="$?"
	log "error" "$action" "failed"
	return "$status"
}

run_compiled_tests() {
	manifest="/tmp/test-binaries/manifest.txt"
	if [ ! -s "$manifest" ]; then
		log "error" "test" "compiled test manifest is missing or empty"
		return 1
	fi

	while read -r binary rel_dir; do
		if [ -z "$binary" ] || [ -z "$rel_dir" ]; then
			log "error" "test" "compiled test manifest contains an invalid entry"
			return 1
		fi
		log "debug" "test" "running compiled test binary"
		(cd "/src/$rel_dir" && "$binary")
	done < "$manifest"
}

check_fmt() {
	unformatted="$(gofmt -l ./cmd ./internal)"
	if [ -n "$unformatted" ]; then
		log "error" "fmt" "gofmt found unformatted files"
		printf '%s\n' "$unformatted" >&2
		return 1
	fi
	return 0
}

log "info" "quality-gates" "running fmt, vet, lint, and tests"
export GOPROXY=off
export GOSUMDB=off
log "debug" "go-env" "disabled module network access"
run_step "fmt" check_fmt
run_step "vet" go vet ./...
run_step "lint" ./bin/golangci-lint run ./...
run_step "test" run_compiled_tests
log "info" "quality-gates" "all quality gates completed"
